---
interface Props {
  id?: string;
  heading?: string;
  subheading?: string;
  buttonText?: string;
}

const {
  id = 'demo-lead-form',
  heading,
  subheading,
  buttonText = 'Book My Free Demo',
} = Astro.props;
---

<div class="demo-lead-form-wrapper w-full">
  {heading && (
    <h3 class:list={['font-display text-xl font-bold text-neutral-900', subheading ? 'mb-1' : 'mb-5']}>{heading}</h3>
  )}
  {subheading && (
    <p class="text-neutral-500 text-sm mb-5">{subheading}</p>
  )}

  <form id={id} class="demo-lead-form pass-tracked-params space-y-3" novalidate>
    <!-- Name row -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div>
        <label for={`${id}-first-name`} class="block text-xs font-medium mb-1 text-neutral-700">First Name</label>
        <input type="text" id={`${id}-first-name`} name="First-Name" placeholder="John" required
          class="w-full rounded-lg border border-neutral-300 px-3 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 outline-none transition focus:border-primary-600 focus:ring-2 focus:ring-primary-600/20" />
        <p class="field-error text-xs mt-1 hidden text-red-600">First name is required.</p>
      </div>
      <div>
        <label for={`${id}-last-name`} class="block text-xs font-medium mb-1 text-neutral-700">Last Name</label>
        <input type="text" id={`${id}-last-name`} name="Last-Name" placeholder="Appleseed" required
          class="w-full rounded-lg border border-neutral-300 px-3 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 outline-none transition focus:border-primary-600 focus:ring-2 focus:ring-primary-600/20" />
        <p class="field-error text-xs mt-1 hidden text-red-600">Last name is required.</p>
      </div>
    </div>

    <!-- Email -->
    <div>
      <label for={`${id}-email`} class="block text-xs font-medium mb-1 text-neutral-700">Work Email</label>
      <input type="email" id={`${id}-email`} name="Email" placeholder="john@example.com" required
        class="w-full rounded-lg border border-neutral-300 px-3 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 outline-none transition focus:border-primary-600 focus:ring-2 focus:ring-primary-600/20" />
      <p class="field-error text-xs mt-1 hidden text-red-600">Work email is required.</p>
    </div>

    <!-- Company Name (auto-derived) -->
    <input type="hidden" name="Company-Name" />

    <!-- Website URL -->
    <div>
      <label for={`${id}-website`} class="block text-xs font-medium mb-1 text-neutral-700">Website URL</label>
      <input type="url" id={`${id}-website`} name="website" placeholder="https://example.com" required
        class="w-full rounded-lg border border-neutral-300 px-3 py-2.5 text-sm text-neutral-900 placeholder-neutral-400 outline-none transition focus:border-primary-600 focus:ring-2 focus:ring-primary-600/20" />
      <p class="field-error text-xs mt-1 hidden text-red-600">Website URL is required.</p>
    </div>

    <!-- Monthly Website Visitors -->
    <div>
      <label for={`${id}-traffic`} class="block text-xs font-medium mb-1 text-neutral-700">Monthly Website Visitors</label>
      <div class="relative">
        <select id={`${id}-traffic`} name="Monthly-Visitors" required
          class="w-full rounded-lg border border-neutral-300 px-3 py-2.5 pr-9 text-sm text-neutral-900 outline-none transition focus:border-primary-600 focus:ring-2 focus:ring-primary-600/20 appearance-none bg-white">
          <option value="">Select monthly visitors</option>
          <option value="<10k">Under 10,000</option>
          <option value="10k-50k">10,000 - 50,000</option>
          <option value="50k-250k">50,000 - 250,000</option>
          <option value="250k-1M">250,000 - 1,000,000</option>
          <option value="1M+">1,000,000+</option>
        </select>
        <svg class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-400" viewBox="0 0 20 20" fill="none">
          <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <p class="field-error text-xs mt-1 hidden text-red-600">Please select your monthly visitors.</p>
    </div>

    <!-- Hidden fields -->
    <input type="hidden" name="Current-Page-URL" class="page-url-field" />

    <!-- Submit -->
    <button type="submit" class="demo-lead-form-submit btn-primary w-full justify-center cursor-pointer mt-4">
      {buttonText}
    </button>

    <p class="text-xs text-center mt-3 text-neutral-400">
      Questions? <a href="mailto:sales@mobiloud.com" class="text-neutral-500 hover:text-neutral-700 transition-colors underline underline-offset-2">sales@mobiloud.com</a>
    </p>

  </form>

  <!-- Calendly context header (hidden until form submit) -->
  <div class="demo-calendly-context hidden text-center px-2 pt-2 pb-5">
    <p class="font-display font-bold text-neutral-900 text-lg mb-1">Pick a time for your free preview call</p>
    <p class="text-neutral-500 text-sm">We'll have your app preview ready before the call. 30 minutes, no commitment.</p>
  </div>

  <!-- Calendly embed (hidden until form submit) -->
  <div class="demo-calendly-container hidden w-full" style="min-height:660px;" data-form-id={id}></div>

  <!-- Low-traffic thank you (hidden until triggered) -->
  <div class="demo-thankyou hidden text-center py-8 px-4">
    <div class="w-12 h-12 rounded-full bg-primary-50 border border-primary-100 flex items-center justify-center mx-auto mb-4">
      <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><path d="M4 10l4.5 4.5 7.5-9" stroke="#047857" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <h3 class="font-display text-lg font-bold text-neutral-900 mb-2">Thanks, we'll be in touch</h3>
    <p class="text-neutral-500 text-sm leading-relaxed">We've got your details. Someone from the team will reach out to talk through next steps.</p>
  </div>
</div>

<script is:inline>
(function() {
  if (window.__demoLeadFormInitialized) return;
  window.__demoLeadFormInitialized = true;


  // Calendly height listener
  window.addEventListener('message', function(ev) {
    if (ev.data.event && ev.data.event === 'calendly.page_height') {
      var height = (ev.data.payload || ev.data.data).height;
      document.querySelectorAll('.demo-calendly-container:not(.hidden)').forEach(function(c) {
        c.style.height = Math.max(parseInt(height), 660) + 'px';
      });
    }
  });

  function initDemoForm() {
    document.querySelectorAll('.demo-lead-form').forEach(function(form) {
      var formId = form.id;
      var websiteInput = form.querySelector('input[type="url"]');
      var pageUrlField = form.querySelector('.page-url-field');
      var calendlyContainer = form.closest('.demo-lead-form-wrapper').querySelector('.demo-calendly-container');

      if (pageUrlField) pageUrlField.value = window.location.href;

      function setFieldError(field, show) {
        var wrapper = field.closest('div');
        var err = wrapper.querySelector('.field-error');
        if (!err) return;
        if (field.type === 'email' && show) {
          var domainErr = wrapper.querySelector('.email-error');
          if (domainErr && !domainErr.classList.contains('hidden')) return;
        }
        if (show) {
          err.classList.remove('hidden');
          field.classList.add('border-red-500');
        } else {
          err.classList.add('hidden');
          field.classList.remove('border-red-500');
        }
      }

      function isFormValid() {
        var allFilled = true;
        form.querySelectorAll('[required]').forEach(function(f) {
          if (!f.value) allFilled = false;
        });
        return allFilled;
      }

      // Blur/input validation for required fields
      form.querySelectorAll('[required]').forEach(function(f) {
        f.addEventListener('blur', function() { setFieldError(f, !f.value); });
        f.addEventListener('input', function() { if (f.value) setFieldError(f, false); });
      });

      // URL auto-format
      if (websiteInput) {
        websiteInput.addEventListener('focus', function() {
          if (!this.value) this.value = 'https://';
        });
        websiteInput.addEventListener('blur', function() {
          if (this.value === 'https://') this.value = '';
        });
        websiteInput.addEventListener('input', function() {
          if (this.value.toLowerCase().startsWith('https://https://')) {
            this.value = this.value.replace(/^https:\/\/https:\/\//i, 'https://');
          }
        });
      }

      // Derive company name from website URL
      function companyFromUrl(url) {
        try {
          var hostname = url.replace(/^https?:\/\//, '').replace(/^www\./, '').split('/')[0].split('?')[0];
          var name = hostname.replace(/\.[^.]+$/, '');
          if (/\.(co|com|org|net|io)\.[a-z]{2,}$/i.test(hostname)) {
            name = hostname.replace(/\.(co|com|org|net|io)\.[a-z]{2,}$/i, '').replace(/^www\./, '');
          }
          return name.split(/[-.]/).map(function(w) {
            return w.charAt(0).toUpperCase() + w.slice(1);
          }).join(' ');
        } catch(e) { return ''; }
      }

      var companyHidden = form.querySelector('input[name="Company-Name"]');
      if (websiteInput && companyHidden) {
        websiteInput.addEventListener('blur', function() {
          var v = this.value.trim();
          if (v && v !== 'https://') companyHidden.value = companyFromUrl(v);
        });
      }

      // Inject UTM params
      var trackedParams = ["utm_source","utm_campaign","utm_medium","utm_term","utm_content","source","campaign","medium","gclid","msclkid"];
      trackedParams.forEach(function(p) {
        var val = localStorage.getItem(p);
        if (val) {
          var input = document.createElement('input');
          input.type = 'hidden';
          input.name = p;
          input.value = val;
          form.appendChild(input);
        }
      });

      // Submit handler
      form.addEventListener('submit', function(e) {
        e.preventDefault();

        if (!isFormValid()) {
          form.querySelectorAll('[required]').forEach(function(f) {
            setFieldError(f, !f.value);
          });
          var firstEmpty = Array.from(form.querySelectorAll('[required]')).find(function(f) { return !f.value; });
          if (firstEmpty) firstEmpty.focus();
          return;
        }

        var formData = {};
        form.querySelectorAll('[name]').forEach(function(f) {
          if (f.value) formData[f.name] = f.value;
        });

        // PostHog capture
        if (typeof posthog !== 'undefined') {
          posthog.capture('Lead Form submitted', formData, { send_instantly: true });
        }

        // GTM
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({ event: 'lead_form_submit', form_id: formId, form_data: formData });

        // Zapier webhook
        var zParams = new URLSearchParams();
        zParams.append('firstName', formData['First-Name'] || '');
        zParams.append('lastName', formData['Last-Name'] || '');
        zParams.append('email', formData['Email'] || '');
        zParams.append('website', formData['website'] || '');
        zParams.append('companyName', formData['Company-Name'] || '');
        zParams.append('monthlyVisitors', formData['Monthly-Visitors'] || '');
        zParams.append('currentPageUrl', formData['Current-Page-URL'] || '');
        fetch('https://hooks.zapier.com/hooks/catch/196687/up8gn25/', { method: 'POST', body: zParams });

        // Traffic qualifying: <10k visitors -> show inline thank you
        var trafficSelect = form.querySelector('select[name="Monthly-Visitors"]');
        if (trafficSelect && trafficSelect.value === '<10k') {
          form.style.display = 'none';
          var formHeadingLow = form.closest('.demo-lead-form-wrapper').querySelector('h3');
          if (formHeadingLow) formHeadingLow.style.display = 'none';
          var thankyouEl = form.closest('.demo-lead-form-wrapper').querySelector('.demo-thankyou');
          if (thankyouEl) thankyouEl.classList.remove('hidden');
          return;
        }

        // Load Calendly inline
        if (typeof Calendly !== 'undefined' && calendlyContainer) {
          form.style.display = 'none';
          // Hide the form heading if present
          var formHeading = form.closest('.demo-lead-form-wrapper').querySelector('h3');
          if (formHeading) formHeading.style.display = 'none';
          // Show context header
          var calendlyContext = form.closest('.demo-lead-form-wrapper').querySelector('.demo-calendly-context');
          if (calendlyContext) calendlyContext.classList.remove('hidden');
          calendlyContainer.classList.remove('hidden');
          calendlyContainer.style.minHeight = '700px';
          calendlyContainer.style.width = '100%';

          Calendly.initInlineWidget({
            url: 'https://calendly.com/mobiloud/mobiloud-app-consultation?hide_gdpr_banner=1&hide_event_type_details=1&background_color=ffffff&primary_color=047857',
            parentElement: calendlyContainer,
            prefill: {
              firstName: form.querySelector('input[name="First-Name"]').value,
              lastName: form.querySelector('input[name="Last-Name"]').value,
              email: form.querySelector('input[name="Email"]').value,
              customAnswers: {
                a1: form.querySelector('input[name="Company-Name"]').value,
                a2: form.querySelector('input[name="website"]').value
              }
            },
            utm: {
              utmCampaign: localStorage.getItem('utm_campaign'),
              utmSource: localStorage.getItem('utm_source'),
              utmMedium: localStorage.getItem('utm_medium'),
              utmContent: localStorage.getItem('utm_content'),
              utmTerm: localStorage.getItem('utm_term')
            }
          });
        } else {
          var params = new URLSearchParams();
          params.set('name', (form.querySelector('input[name="First-Name"]').value + ' ' + form.querySelector('input[name="Last-Name"]').value).trim());
          params.set('email', form.querySelector('input[name="Email"]').value);
          window.location.href = 'https://www.mobiloud.com/demo?' + params.toString();
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemoForm);
  } else {
    initDemoForm();
  }
})();
</script>
