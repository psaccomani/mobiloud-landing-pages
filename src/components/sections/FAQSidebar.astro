---
import Container from '../ui/Container.astro';

const faqs = [
  {
    q: 'How is MobiLoud different from Tapcart or Shopney?',
    a: 'App builders like Tapcart rebuild your store from scratch using templates, which means you lose custom features and need to maintain two separate experiences. MobiLoud turns your existing website into your app, so everything you already have works automatically with zero duplicate maintenance.',
  },
  {
    q: "What's your process like?",
    a: "It starts with a consultation to understand your vision and requirements. After sign-up, we schedule an onboarding call to discuss customization options. Our team then develops your app, prepares custom graphics, and shares a preview for your feedback. After testing, we submit to the App Store and Google Play, monitor approvals, and keep you updated until your app is live. We also provide marketing advice, ready-to-use assets, and push notification strategy sessions to help you promote it effectively.",
  },
  {
    q: 'Does it work with Shopify?',
    a: 'Yes, MobiLoud works perfectly with Shopify and Shopify Plus. Your app syncs completely with your Shopify store, including all your products, collections, and third-party app integrations. Your checkout, analytics, and customer accounts all work seamlessly.',
  },
  {
    q: 'Does it work with Shopify Plus?',
    a: 'Yes. MobiLoud is fully compatible with Shopify Plus. Because your app is powered by your live site, all your Plus features and customizations carry over automatically.',
  },
  {
    q: 'Does it work with any Shopify theme?',
    a: 'Yes. MobiLoud works with every Shopify theme. Because your app is powered by your live site, your theme and all its customizations carry over automatically.',
  },
  {
    q: 'Do we have to manage and update the app ourselves?',
    a: "Not at all. MobiLoud is a fully managed service, which means we handle all the technical aspects of the app for you. Your team's focus remains on running your website and your business. We act as your dedicated app team, covering initial configuration, app store submission, and all ongoing maintenance and updates.",
  },
  {
    q: 'Can we customize the app experience so it\'s different than the website?',
    a: 'Yes. While your app syncs with your website by default, you can customize native elements like the tab bar, splash screen, and app icon. You can also create app-exclusive content, show different promotions for app users, or tailor the navigation to suit the mobile experience.',
  },
  {
    q: 'What happens after launch?',
    a: "We stay involved after your app goes live. Our team handles ongoing maintenance, keeps your app compliant with App Store and Google Play requirements, and manages all platform and OS updates. We also help you set up push notification and engagement flows. On Corporate plans, you get a dedicated Customer Success Manager with regular meetings and strategy guidance.",
  },
  {
    q: 'Do you support multilingual or multi-country stores?',
    a: 'Yes. MobiLoud supports multi-language and multi-country stores via additional configurations. Each configuration gets its own language UI, URLs, and targeted push notifications. Additional configurations are priced at $100/mo on top of your standard plan.',
  },
  {
    q: 'Do you have a refund policy?',
    a: "Setup fees, monthly fees, and annual fees are non-refundable. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid (not setup fees). You can cancel anytime with 30 days written notice if you're not on a contract.",
  },
];
---

<section class="py-20 bg-background">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
      <!-- Left sidebar -->
      <div class="lg:sticky lg:top-24 lg:self-start">
        <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
        <p class="text-neutral-600 text-base leading-relaxed mb-6">
          Still have questions? Get a free preview and we'll walk you through everything.
        </p>
        <a href="https://www.mobiloud.com/demo" class="btn-primary cursor-pointer text-sm !py-2.5 !px-5">Get Your Free Preview</a>
      </div>

      <!-- Right: FAQ accordion -->
      <div class="space-y-0">
        {faqs.map((faq, i) => (
          <div class="border-b border-neutral-200">
            <button
              class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
              aria-expanded="false"
              data-faq-index={i}
            >
              <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
              <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="faq-answer" data-faq-answer={i}>
              <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
