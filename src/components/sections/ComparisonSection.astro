---
import Container from '../ui/Container.astro';

const problems = [
  {
    title: 'You have to rebuild your store',
    description: 'App builders like Tapcart and Shopney use templates and drag-and-drop editors. You recreate your store from scratch in their platform.',
  },
  {
    title: 'Double the maintenance',
    description: 'Every change you make on your website needs to be replicated in your app. Two platforms to manage, forever.',
  },
  {
    title: 'Your features don\'t carry over',
    description: 'They rely on the Shopify Storefront API, which means custom code, third-party tools, and complex features get lost.',
  },
  {
    title: 'Costs escalate at scale',
    description: 'Revenue share fees of 1.75-2.5% on in-app sales mean the more successful your app is, the more you pay.',
  },
];

const solutions = [
  {
    title: 'Your existing site becomes your app',
    description: 'MobiLoud turns your live website into your app. Your design, features, and custom code all work automatically.',
  },
  {
    title: 'Zero extra maintenance',
    description: 'Change your site once, your app updates instantly. One platform to manage, always in sync.',
  },
  {
    title: 'Everything works out of the box',
    description: 'Every Shopify app, third-party integration, and custom feature you already use works in your app with no rebuilding.',
  },
  {
    title: 'Simple, predictable pricing',
    description: 'No revenue share, no success fees. Straightforward monthly pricing that keeps things simple.',
  },
];
---

<section class="py-20 bg-neutral-50">
  <Container>
    <div class="text-center mb-14">
      <h2 class="font-display text-display-3 text-heading" id="shopify-app-builder-comparison" aria-label="Compare Shopify mobile app builders">App builders make you start from scratch. We don't.</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 max-w-5xl mx-auto">
      <!-- Problem -->
      <div class="border border-neutral-200 rounded-card p-8 lg:p-10 bg-white">
        <p class="text-red-600 font-semibold text-sm uppercase tracking-wide mb-6">The problem with app builders</p>
        <div class="space-y-6">
          {problems.map((p) => (
            <div class="flex gap-3">
              <span class="flex-shrink-0 mt-1">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#DC2626"/><path d="M5.5 5.5L10.5 10.5M10.5 5.5L5.5 10.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
              </span>
              <div>
                <p class="font-display font-bold text-neutral-900 text-base mb-1">{p.title}</p>
                <p class="text-neutral-500 text-sm leading-relaxed">{p.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Solution -->
      <div class="border-2 border-primary-600 rounded-card p-8 lg:p-10 bg-primary-50">
        <p class="text-primary-700 font-semibold text-sm uppercase tracking-wide mb-6">How MobiLoud is different</p>
        <div class="space-y-6">
          {solutions.map((s) => (
            <div class="flex gap-3">
              <span class="flex-shrink-0 mt-1">
                <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#047857"/><path d="M5 8L7 10L11 6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <div>
                <p class="font-display font-bold text-neutral-900 text-base mb-1">{s.title}</p>
                <p class="text-neutral-500 text-sm leading-relaxed">{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="text-center mt-10">
      <a href="#lead-form-section" class="btn-primary cursor-pointer" style="cursor: pointer;">See the Difference for Yourself</a>
    </div>
  </Container>
</section>
