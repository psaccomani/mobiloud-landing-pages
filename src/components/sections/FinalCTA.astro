---
import Container from '../ui/Container.astro';
const base = import.meta.env.BASE_URL;
---

<section class="py-20" style="background: linear-gradient(135deg, #047857 0%, #065f46 100%)">
  <Container>
    <div class="max-w-3xl mx-auto text-center">
      <h3 class="font-display text-display-3 text-white mb-4">See your store as a native app. Free preview, no commitment.</h3>
      <p class="text-primary-100 text-base leading-relaxed mb-8 max-w-2xl mx-auto">Get a working preview of your Shopify store as a native iOS and Android app. No code, no commitment. If you love it, we'll build and launch it in 30 days.</p>

      <a href="https://www.mobiloud.com/demo" class="inline-flex items-center justify-center bg-white text-primary-800 rounded-[10px] px-8 py-4 font-display font-semibold text-base hover:bg-primary-50 transition-colors shadow-lg">Get Your Free Preview</a>

      <!-- Logo strip -->
      <div class="flex items-center justify-center gap-6 sm:gap-10 pt-10 mt-10 border-t border-white/20">
        <img src={`${base}images/jack--jones.svg`} alt="Jack & Jones" width="80" height="20" class="h-4 w-auto opacity-40 brightness-0 invert" loading="lazy">
        <img src={`${base}images/bestseller-logo.webp`} alt="Bestseller" width="90" height="20" class="h-4 w-auto opacity-40 brightness-0 invert" loading="lazy">
        <img src={`${base}images/buybuybaby-logo.svg`} alt="BuyBuyBaby" width="90" height="20" class="h-4 w-auto opacity-40 brightness-0 invert" loading="lazy">
        <img src={`${base}images/john-varvatos.svg`} alt="John Varvatos" width="80" height="20" class="h-4 w-auto opacity-40 brightness-0 invert" loading="lazy">
      </div>
    </div>
  </Container>
</section>
