---
import Container from '../ui/Container.astro';
import DemoLeadForm from '../ui/DemoLeadForm.astro';
const base = import.meta.env.BASE_URL;

const bullets = [
  {
    title: 'A working app preview',
    body: 'We build a real preview from your live site so you can see exactly what your customers would experience.',
  },
  {
    title: 'Your revenue model',
    body: 'We map out the incremental revenue opportunity a mobile app represents for your store, based on your traffic and platform.',
  },
  {
    title: 'A concrete path to launch',
    body: 'A specific timeline, clear pricing, and a launch plan. You leave knowing exactly what happens next.',
  },
];
---

<section class="relative py-24 overflow-hidden" id="get-started">
  <!-- Animated background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-800 via-primary-700 to-emerald-900">
    <!-- Floating orbs -->
    <div class="cta-orb cta-orb-1"></div>
    <div class="cta-orb cta-orb-2"></div>
    <div class="cta-orb cta-orb-3"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; viewBox=&quot;0 0 40 40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;white&quot; stroke-width=&quot;0.5&quot;/%3E%3C/svg%3E');"></div>
  </div>

  <Container>
    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Left: pitch -->
      <div class="pt-2">
        <h3 class="font-display text-display-2 text-white mb-4 lg:text-[48px] lg:leading-[56px]">Get the business case for your mobile app</h3>
        <p class="text-primary-100/80 text-lg leading-relaxed mb-10">Book a call and we'll build a working preview of your app and model the revenue opportunity for your store. No cost, no commitment.</p>

        <ol class="space-y-6">
          {bullets.map((b, i) => (
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-white text-xs font-bold">{i + 1}</span>
              <div>
                <p class="text-white font-semibold text-sm mb-0.5">{b.title}</p>
                <p class="text-primary-100/70 text-sm leading-relaxed">{b.body}</p>
              </div>
            </li>
          ))}
        </ol>

        <!-- Logo strip -->
        <div class="flex items-center gap-6 sm:gap-10 mt-10">
          <img src={`${base}/images/jack--jones.svg`} alt="Jack & Jones" width="80" height="20" class="h-4 w-auto opacity-30 brightness-0 invert" loading="lazy">
          <img src={`${base}/images/bestseller-logo.webp`} alt="Bestseller" width="90" height="20" class="h-4 w-auto opacity-30 brightness-0 invert" loading="lazy">
          <img src={`${base}/images/buybuybaby-logo.svg`} alt="BuyBuyBaby" width="90" height="20" class="h-4 w-auto opacity-30 brightness-0 invert" loading="lazy">
          <img src={`${base}/images/john-varvatos.svg`} alt="John Varvatos" width="80" height="20" class="h-4 w-auto opacity-30 brightness-0 invert" loading="lazy">
        </div>
      </div>

      <!-- Right: form card -->
      <div class="bg-white rounded-2xl p-8 sm:p-10 shadow-2xl">
        <DemoLeadForm id="cta-form" heading="Book a free demo" subheading="30 minutes. We'll walk you through an ROI estimate, a working preview of your app, and a plan to go live in 30 days." buttonText="Book My Free Demo" />
      </div>

    </div>

    <!-- Trust indicators -->
    <div class="relative z-10 flex flex-wrap items-center justify-center gap-8 mt-16 pt-10 border-t border-white/15">
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 1L12.39 5.84L17.73 6.62L13.87 10.39L14.78 15.71L10 13.27L5.22 15.71L6.13 10.39L2.27 6.62L7.61 5.84L10 1Z" fill="#F59E0B"/></svg>
        <span class="text-white/70 text-sm font-medium">4.7/5 average rating</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="8" stroke="#34D399" stroke-width="2"/><path d="M7 10L9 12L13 8" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="text-white/70 text-sm font-medium">2,000+ apps launched</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2V18M14 6H8C6.89543 6 6 6.89543 6 8C6 9.10457 6.89543 10 8 10H12C13.1046 10 14 10.8954 14 12C14 13.1046 13.1046 14 12 14H6" stroke="#34D399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="text-white/70 text-sm font-medium">No revenue share</span>
      </div>
    </div>
  </Container>
</section>

<style>
  .cta-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.3;
  }

  .cta-orb-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #34d399 0%, transparent 70%);
    top: -100px;
    right: -100px;
    animation: float-1 8s ease-in-out infinite;
  }

  .cta-orb-2 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #10b981 0%, transparent 70%);
    bottom: -80px;
    left: -80px;
    animation: float-2 10s ease-in-out infinite;
  }

  .cta-orb-3 {
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, #6ee7b7 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation: float-3 6s ease-in-out infinite;
  }

  @keyframes float-1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-30px, 20px); }
  }

  @keyframes float-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(20px, -30px); }
  }

  @keyframes float-3 {
    0%, 100% { transform: translate(-50%, -50%) scale(1); }
    50% { transform: translate(-50%, -50%) scale(1.2); }
  }
</style>
