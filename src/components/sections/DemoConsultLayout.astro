---
import DemoLeadForm from '../ui/DemoLeadForm.astro';
const base = import.meta.env.BASE_URL;

const bullets = [
  {
    title: 'A working app preview',
    body: 'We build a real preview from your live site so you can see exactly what your customers would experience.',
  },
  {
    title: 'Your revenue model',
    body: 'We map out the incremental revenue opportunity a mobile app represents for your store, based on your traffic and platform.',
  },
  {
    title: 'A concrete path to launch',
    body: 'A specific timeline, clear pricing, and a launch plan. You leave knowing exactly what happens next.',
  },
];
---

<style>
  *, *::before, *::after { box-sizing: border-box; }

  .demo-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    background: linear-gradient(135deg, #1a1a2e 0%, #171717 40%, #0f2016 100%);
    font-family: 'Inter', Arial, sans-serif;
    color: #fff;
  }

  /* ── Header ── */
  .demo-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 56px;
    height: 64px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    flex-shrink: 0;
  }

  .demo-header a.contact {
    color: #d1d5db;
    font-size: 13px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .demo-header a.contact:hover { color: #ffffff; }

  /* ── Main two-col ── */
  .demo-main {
    flex: 1;
    display: flex;
  }

  /* ── Left content ── */
  .demo-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 56px 56px 56px 56px;
    gap: 0;
  }

  .demo-headline {
    font-family: 'Eudoxus Sans', Arial, sans-serif;
    font-size: 52px;
    line-height: 1.06;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.03em;
    margin: 0 0 18px;
  }

  .demo-sub {
    color: #9ca3af;
    font-size: 17px;
    line-height: 1.65;
    margin: 0 0 40px;
    max-width: 520px;
  }

  /* Bullets */
  .bullets {
    list-style: none;
    margin: 0 0 48px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .bullet {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .bullet-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(4,120,87,0.15);
    border: 1px solid rgba(4,120,87,0.35);
    color: #34d399;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .bullet-title {
    font-family: 'Eudoxus Sans', Arial, sans-serif;
    color: #f3f4f6;
    font-size: 14px;
    font-weight: 600;
    display: block;
    margin-bottom: 3px;
  }

  .bullet-body {
    color: #9ca3af;
    font-size: 14px;
    line-height: 1.55;
  }

  /* Testimonial */
  .testimonial {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding-top: 28px;
    max-width: 440px;
  }

  .testimonial-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 10px;
  }

  .testimonial blockquote {
    margin: 0 0 14px;
    color: #d1d5db;
    font-size: 14px;
    line-height: 1.7;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .testimonial-author-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testimonial-author img.avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
  }

  .author-name {
    font-family: 'Eudoxus Sans', Arial, sans-serif;
    color: #f9fafb;
    font-size: 13px;
    font-weight: 600;
    display: block;
  }

  .author-role {
    color: #6b7280;
    font-size: 12px;
  }

  /* ── Right panel ── */
  .demo-right {
    width: 580px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    padding: 48px 56px 48px 24px;
  }

  /* Form card */
  .form-card {
    background: #ffffff;
    border-radius: 16px;
    width: 100%;
    padding: 36px 40px;
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.04),
      0 32px 80px rgba(0,0,0,0.5),
      0 0 60px rgba(4,120,87,0.07);
  }

  .form-heading {
    font-family: 'Eudoxus Sans', Arial, sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 4px;
    letter-spacing: -0.02em;
  }

  .form-sub {
    color: #6b7280;
    font-size: 14px;
    line-height: 1.5;
    margin: 0 0 20px;
  }

  .trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #f3f4f6;
  }

  /* ── Footer ── */
  .demo-footer {
    padding: 0 56px;
    height: 48px;
    border-top: 1px solid rgba(255,255,255,0.07);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
  }

  .demo-footer span,
  .demo-footer a {
    color: #4b5563;
    font-size: 12px;
    text-decoration: none;
  }

  .demo-footer a:hover { color: #9ca3af; }

  /* ── Mobile ── */
  @media (max-width: 1023px) {
    .demo-header { padding: 0 24px; }
    .demo-main { flex-direction: column; }
    .demo-left {
      justify-content: flex-start;
      padding: 40px 24px 32px;
    }
    .demo-headline { font-size: 32px; }
    .demo-right { width: 100%; padding: 0 24px 40px; }
    .demo-footer { padding: 0 24px; }
  }
</style>

<style is:global>
  body.demo-body { padding-bottom: 0 !important; }
</style>

<script is:inline>document.body.classList.add('demo-body');</script>

<div class="demo-page">

  <!-- Header -->
  <header class="demo-header">
    <a href="https://www.mobiloud.com">
      <img src={`${base}/images/logomark-white-2025.svg`} alt="MobiLoud" width="136" height="30" loading="eager">
    </a>
    <a href="mailto:sales@mobiloud.com" class="contact">Questions? sales@mobiloud.com</a>
  </header>

  <!-- Main -->
  <div class="demo-main">

    <!-- Left -->
    <div class="demo-left">

      <h1 class="demo-headline">Get the business case<br>for your mobile app</h1>
      <p class="demo-sub">Book a call and we'll build a working preview of your app and model the revenue opportunity for your store. No cost, no commitment.</p>

      <ol class="bullets">
        {bullets.map((b, i) => (
          <li class="bullet">
            <span class="bullet-num">{i + 1}</span>
            <div>
              <span class="bullet-title">{b.title}</span>
              <span class="bullet-body">{b.body}</span>
            </div>
          </li>
        ))}
      </ol>

      <div class="testimonial">
        <div class="testimonial-stars">
          {Array.from({length: 5}).map(() => (
            <svg width="14" height="14" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78L10 1z"/></svg>
          ))}
        </div>
        <blockquote>"We couldn't find another company that could offer the same features at the same price point, same time to market, and make it as easy as MobiLoud could."</blockquote>
        <div class="testimonial-author">
          <div class="testimonial-author-left">
            <img src={`${base}/images/svend-hansen.avif`} alt="Svend Hansen" class="avatar" width="36" height="36" loading="lazy">
            <div>
              <span class="author-name">Svend Hansen</span>
              <span class="author-role">Product Owner</span>
            </div>
          </div>
          <img src={`${base}/images/bestseller-white.svg`} alt="Bestseller" style="height:16px;width:auto;opacity:0.5;" loading="lazy">
        </div>
      </div>

    </div>

    <!-- Right -->
    <div class="demo-right">
      <div class="form-card">
        <h2 class="form-heading">Book your free demo</h2>
        <p class="form-sub">We'll build your app preview and walk you through the numbers. No cost, no commitment.</p>
        <DemoLeadForm id="demo-consult-form" buttonText="Book My Free Demo" />
        <div class="trust-row">
          <img src={`${base}/images/G2-Review-Badge.svg`} alt="G2" style="height:36px;width:auto;" loading="lazy">
          <img src={`${base}/images/capterra-rating-badge_1.svg`} alt="Capterra" style="height:36px;width:auto;" loading="lazy">
        </div>
      </div>
    </div>

  </div>

  <!-- Footer -->
  <footer class="demo-footer">
    <span>&copy; 2026 Fifty Pixels Ltd.</span>
    <div style="display:flex;gap:20px;">
      <a href="https://www.mobiloud.com/privacy-policy">Privacy Policy</a>
      <a href="https://www.mobiloud.com/terms">Terms</a>
    </div>
  </footer>

</div>

<script is:inline>
(function() {
  if (window.__demoConsultObserver) return;
  window.__demoConsultObserver = true;
  var rightPanel = document.querySelector('.demo-right');
  if (!rightPanel) return;
  var h2 = rightPanel.querySelector('.form-heading');
  var sub = rightPanel.querySelector('.form-sub');
  var trust = rightPanel.querySelector('.trust-row');
  var observer = new MutationObserver(function() {
    if (rightPanel.querySelector('.demo-calendly-container:not(.hidden)')) {
      if (h2) h2.style.display = 'none';
      if (sub) sub.style.display = 'none';
      if (trust) trust.style.display = 'none';
    }
  });
  observer.observe(rightPanel, { attributes: true, childList: true, subtree: true });
})();
</script>
