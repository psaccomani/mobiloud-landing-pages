---
import Container from '../ui/Container.astro';
---

<section class="py-16 bg-primary-700" style="background: linear-gradient(135deg, #047857 0%, #065f46 100%)">
  <Container>
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div>
        <h3 class="font-display text-display-4 text-white mb-2">See your store as a native app</h3>
        <p class="text-primary-100 text-base max-w-lg">Get a free, working preview of your store as an iOS and Android app. No code, no commitment. Join 2,000+ brands already using MobiLoud.</p>
      </div>
      <div class="flex flex-wrap gap-3 shrink-0">
        <a href="#lead-form-section" class="cursor-pointer inline-flex items-center justify-center bg-white text-primary-800 rounded-[10px] px-6 py-3.5 font-display font-semibold text-base hover:bg-primary-50 transition-colors shadow-lg">Get Your Free Preview</a>
        <a href="#get-started" class="cursor-pointer inline-flex items-center justify-center bg-transparent text-white border-2 border-white/50 rounded-[10px] px-6 py-3.5 font-display font-semibold text-base hover:bg-white/10 transition-colors">Book a Demo</a>
      </div>
    </div>
  </Container>
</section>
