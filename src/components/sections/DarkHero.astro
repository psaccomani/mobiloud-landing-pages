---
import Container from '../ui/Container.astro';
import LeadForm from '../ui/LeadForm.astro';
const base = import.meta.env.BASE_URL;

const valueProps = [
  'A real preview of your app, built from your live store',
  'Live on the App Store and Google Play in 30 days',
  'Flat monthly pricing, no revenue share',
];


---

<section class="bg-neutral-900 pt-16 pb-20 overflow-hidden" style="background: linear-gradient(135deg, #1a1a2e 0%, #171717 40%, #0f2016 100%)">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Left: Text -->
      <div class="pt-2">
        <p class="text-primary-400 font-semibold text-sm uppercase tracking-wide mb-4" id="shopify-mobile-app">A Better Mobile App Builder For Shopify</p>
        <h1 class="font-display text-display-1 text-white mb-6 lg:text-[60px] lg:leading-[68px]" id="turn-shopify-store-into-app" aria-label="Turn your Shopify store into a mobile app">Turn Your Shopify Store into a Mobile App. Live in 30 days.</h1>
        <p class="text-neutral-400 text-lg leading-relaxed mb-10 max-w-lg">Give your best customers a reason to keep coming back. Launch a native iOS and Android app that syncs with your Shopify store.</p>

        <ul class="space-y-3">
          {valueProps.map((vp) => (
            <li class="flex items-center gap-3">
              <span class="flex-shrink-0 w-5 h-5 bg-primary-700 rounded-full flex items-center justify-center">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6L5 8.5L9.5 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              <p class="text-neutral-300 text-sm">{vp}</p>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: Lead form -->
      <div id="lead-form-section">
        <div class="w-full max-w-md mx-auto lg:mx-0 lg:ml-auto">
          <LeadForm id="hero-form" variant="dark" heading="Get a free preview of your mobile app" subheading="We build a working preview from your live Shopify store and walk you through it on a 30-minute call. See what your customers would actually experience, before you commit." />
          <p class="text-neutral-400 text-xs text-center mt-3">
            Prefer email? <a href="mailto:sales@mobiloud.com" class="text-neutral-300 hover:text-white transition-colors underline underline-offset-2">sales@mobiloud.com</a>
          </p>
        </div>
      </div>
    </div>

    <!-- Badge row -->
    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4 mt-14 pt-10 border-t border-neutral-800">
      <span class="text-neutral-500 text-sm font-medium">Trusted by 2,000+ brands</span>
      <img src={`${base}/images/G2-Review-Badge.svg`} alt="G2 Review Badge" width="54" height="60" class="h-[46px] w-auto" loading="eager">
      <img src={`${base}/images/capterra-rating-badge_1.svg`} alt="Capterra Rating Badge" width="162" height="54" class="h-[46px] w-auto" loading="eager">
      <img src={`${base}/images/producthunt-badge.svg`} alt="Product Hunt Badge" width="250" height="54" class="h-[46px] w-auto" loading="eager">
    </div>
  </Container>
</section>
