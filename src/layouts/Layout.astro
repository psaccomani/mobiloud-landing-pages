  posthog.init('phc_CBWKc0UCgO97lBsNr4u47Q9BUqatILguFFnLM1f1Agq',{api_host:'https://d2v0eihtpm87uj.cloudfront.net',disable_session_recording:true,enable_recording_console_log:true});</script>
</head>
<body class="overflow-x-hidden pb-[72px] md:pb-0">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MJHN9HX" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <slot />

  <!-- Hash link scroll: two-phase approach to handle lazy-image layout shift -->
  <script is:inline>
  (function() {
    var NAV_OFFSET = 88;
    function getScrollTop(el) {
      return Math.max(0, el.getBoundingClientRect().top + window.scrollY - NAV_OFFSET);
    }
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href^="#"]');
      if (!link) return;
      var hash = link.getAttribute('href');
      if (!hash || hash === '#' || !hash.startsWith('#')) return;
      var target = document.getElementById(hash.slice(1));
      if (!target) return;
      e.preventDefault();
      function scrollNow() {
        // Phase 1: smooth scroll with best current estimate
        window.scrollTo({ top: getScrollTop(target), behavior: 'smooth' });
        // Phase 2: instant correction after scroll animation + newly triggered lazy images settle
        setTimeout(function() {
          var exact = getScrollTop(target);
          if (Math.abs(exact - window.scrollY) > 20) {
            window.scrollTo({ top: exact, behavior: 'instant' });
          }
        }, 1000);
      }
      // Wait up to 400ms for images already in flight before phase 1
      var pending = Array.from(document.images).filter(function(img) { return !img.complete; });
      if (!pending.length) { scrollNow(); return; }
      var done = 0;
      var timeout = setTimeout(scrollNow, 400);
      pending.forEach(function(img) {
        function onSettle() { if (++done === pending.length) { clearTimeout(timeout); scrollNow(); } }
        img.addEventListener('load', onSettle, { once: true });
        img.addEventListener('error', onSettle, { once: true });
      });
    });
  })();
  </script>

  <!-- UTM tracking: save to localStorage, inject into forms and outbound links -->
  <script is:inline>
  (function() {
    var trackedParams = ["utm_source", "utm_campaign", "utm_medium", "utm_term", "utm_content", "source", "campaign", "medium", "gclid", "msclkid"];
    var queryParams = new URLSearchParams(window.location.search);
    queryParams.forEach(function(value, key) {
      if (trackedParams.indexOf(key) !== -1) localStorage.setItem(key, value);
    });
    // Capture landing page URL on first visit (clean, without query params)
    if (!localStorage.getItem('landing_page')) {
      localStorage.setItem('landing_page', window.location.href);
    }
    // Capture referrer on first visit
    if (!localStorage.getItem('referrer') && document.referrer) {
      localStorage.setItem('referrer', document.referrer);
    }
    // Inject stored UTMs + landing page + referrer as hidden fields into forms
    var allTrackedFields = trackedParams.concat(["landing_page", "referrer"]);
    document.querySelectorAll("form.pass-tracked-params").forEach(function(form) {
      allTrackedFields.forEach(function(p) {
        if (localStorage.getItem(p)) {
          var input = document.createElement("input");
          input.type = "hidden"; input.name = p; input.value = localStorage.getItem(p);
          form.appendChild(input);
        }
      });
    });
    // Append stored UTMs to outbound CTA links (mobiloud.com/demo and app.mobiloud.com)
    document.querySelectorAll('a[href*="mobiloud.com/demo"], a[href*="app.mobiloud.com"]').forEach(function(link) {
      try {
        var url = new URL(link.href);
        var paramAdded = false;
        trackedParams.forEach(function(p) {
          var val = localStorage.getItem(p);
          if (val) { url.searchParams.set(p, val); paramAdded = true; }
        });
        if (paramAdded) link.href = url.toString();
      } catch(e) {}
    });
  })();
  </script>

</body>
</html>
