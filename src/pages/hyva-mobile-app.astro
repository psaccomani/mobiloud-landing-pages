---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import ValueProp from '../components/sections/ValueProp.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import LeadForm from '../components/ui/LeadForm.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL;

const hyvaProblems = [
  {
    title: 'A PWA is not an app store app',
    description: 'PWAs cannot be listed on the App Store or Google Play as standalone apps. Customers cannot discover, download, or install your store the way they expect from a real app.',
  },
  {
    title: 'Rebuilding loses the Hyvä advantage',
    description: 'React Native or Flutter app builds require recreating your entire storefront in a new codebase, losing the performance and simplicity that Hyvä gives you.',
  },
  {
    title: 'Your extensions and customizations get dropped',
    description: 'Template-based app builders cannot replicate Magento extensions, custom Alpine.js components, or Hyvä-specific UI patterns. You lose functionality you depend on.',
  },
  {
    title: 'Double the maintenance, forever',
    description: 'Every theme update, extension change, or product addition needs to be reflected in a separate app platform. That overhead compounds over time.',
  },
];

const hyvaSolutions = [
  {
    title: 'Your Hyvä storefront becomes your app',
    description: 'MobiLoud turns your live Hyvä site into an iOS and Android app. Your Alpine.js components, Tailwind styles, and custom code all carry over automatically.',
  },
  {
    title: 'The Hyvä performance carries into the app',
    description: 'Fast page loads, optimised Core Web Vitals, and lightweight Alpine.js interactivity all transfer directly. Hyvä-powered apps feel particularly responsive.',
  },
  {
    title: 'Every Magento extension works out of the box',
    description: 'Because MobiLoud turns your live site into an app rather than rebuilding it, every extension and custom module carries over with no extra configuration.',
  },
  {
    title: 'One update, everywhere',
    description: 'Keep managing your Hyvä storefront as you always have. Your app updates automatically whenever your site changes, with no separate platform to manage.',
  },
];

const hyvaFaqs = [
  {
    q: 'Does MobiLoud work with Hyvä Core theme?',
    a: 'Yes. Hyvä Core runs in the browser like any other storefront, so MobiLoud turns it into an iOS and Android app without any modifications or custom integration. Your Hyvä design, components, and Alpine.js interactivity all work automatically in the app.',
  },
  {
    q: 'Does it work with Hyvä Checkout?',
    a: 'Yes. Hyvä Checkout runs in the browser and carries over into the app experience without any changes. Customers go through the same fast, optimised checkout flow inside your app as they do on your website.',
  },
  {
    q: 'Does it work with Breeze theme?',
    a: 'Yes. Breeze is a lightweight Hyvä alternative built on the same Alpine.js and Tailwind CSS principles, and MobiLoud works with it exactly the same way. If it runs in a browser, it works as an app.',
  },
  {
    q: 'Will the Hyvä performance carry over into the app?',
    a: 'Yes. The speed advantages of Hyvä — fast page loads, optimised Core Web Vitals, lightweight frontend — all carry directly into your app experience. Hyvä-powered apps tend to feel particularly responsive compared to apps built on heavier storefronts.',
  },
  {
    q: 'Do my Magento extensions still work in the app?',
    a: 'Yes. Every extension running on your Magento site works in the app automatically. Because MobiLoud turns your live website into an app rather than rebuilding it from an API, there is no integration work required and nothing needs to be re-configured.',
  },
  {
    q: 'Is this different from building a PWA on top of Hyvä?',
    a: 'Yes, significantly. A PWA is still a website accessed through a browser — it cannot be listed in the App Store or Google Play as a standalone app. MobiLoud gives you a real iOS and Android app, distributed through both app stores, with push notifications, a native shell, and a proper app store presence. No rebuilding required.',
  },
  {
    q: 'How long does it take to launch?',
    a: 'Most stores go live in 30 days or less. That includes onboarding, app customisation, testing, and submission to the App Store and Google Play. We manage the entire process and keep you updated at each step.',
  },
  {
    q: 'Do I need a Hyvä developer or Magento agency to set this up?',
    a: 'No. MobiLoud is a fully managed service. You do not need to involve your development team or your Magento agency. We handle all the technical work on our side. Your team just reviews and approves.',
  },
];
---

<Layout
  title="Hyvä Mobile App Builder — MobiLoud"
  description="Turn your Hyvä Magento store into an iOS and Android app in 30 days. Hyvä Core, Hyvä Checkout, and Breeze all supported. No rebuild, no extra maintenance."
>
  <Nav />

  <!-- Hyvä Hero -->
  <section class="bg-neutral-900 pt-16 pb-20 overflow-hidden" style="background: linear-gradient(135deg, #1a1a2e 0%, #171717 40%, #0f2016 100%)">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <p class="text-primary-400 font-semibold text-sm uppercase tracking-wide mb-4" id="hyva-mobile-app">The Best Mobile App Builder for Hyvä-Powered Magento Stores</p>
          <h1 class="font-display text-display-1 text-white mb-6 lg:text-[60px] lg:leading-[68px]" id="turn-hyva-store-into-app" aria-label="Turn your Hyvä Magento store into a mobile app">Turn Your Hyvä Magento Store into a Mobile App. Live in 30 days.</h1>
          <p class="text-neutral-400 text-lg leading-relaxed mb-8 max-w-lg">Your Hyvä storefront is already fast and mobile-optimised. Now make it an app. Launch iOS and Android in 30 days — no rebuild, no extra maintenance. Hyvä Core, Hyvä Checkout, and Breeze all supported.</p>

          <ul class="space-y-3 mb-8">
            <li class="flex items-start gap-3 text-neutral-300 text-sm">
              <span class="flex-shrink-0 w-5 h-5 bg-primary-700 rounded-full flex items-center justify-center mt-0.5">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6L5 8.5L9.5 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Your Hyvä performance carries into the app — blazing-fast mobile experience
            </li>
            <li class="flex items-start gap-3 text-neutral-300 text-sm">
              <span class="flex-shrink-0 w-5 h-5 bg-primary-700 rounded-full flex items-center justify-center mt-0.5">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6L5 8.5L9.5 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Works with Hyvä Core, Hyvä Checkout, Breeze, and all Magento 2 extensions
            </li>
            <li class="flex items-start gap-3 text-neutral-300 text-sm">
              <span class="flex-shrink-0 w-5 h-5 bg-primary-700 rounded-full flex items-center justify-center mt-0.5">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 6L5 8.5L9.5 4" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
              Simple monthly pricing. No revenue share, no success fees
            </li>
          </ul>
        </div>

        <!-- Right: Lead form -->
        <div class="flex justify-center" id="lead-form-section">
          <div class="w-full max-w-md">
            <LeadForm id="hero-form" variant="dark" heading="Get a free preview of your mobile app" subheading="We build a working preview from your live Hyvä storefront and walk you through it on a 30-minute call. See what your customers would actually experience, before you commit." />
          </div>
        </div>
      </div>

      <!-- Badge row -->
      <div class="flex flex-wrap items-center justify-center gap-6 mt-16 pt-10 border-t border-neutral-800">
        <img src={`${base}/images/G2-Review-Badge.svg`} alt="G2 Review Badge" width="54" height="60" class="h-[54px] w-auto" loading="eager">
        <img src={`${base}/images/capterra-rating-badge_1.svg`} alt="Capterra Rating Badge" width="162" height="54" class="h-[54px] w-auto" loading="eager">
        <img src={`${base}/images/producthunt-badge.svg`} alt="Product Hunt Badge" width="250" height="54" class="h-[54px] w-auto" loading="eager">
      </div>
    </Container>
  </section>

  <LogoMarquee />

  <!-- Comparison -->
  <section class="py-20 bg-neutral-50">
    <Container>
      <div class="text-center mb-14">
        <h2 class="font-display text-display-3 text-heading" id="hyva-app-builder-comparison" aria-label="Compare Hyvä mobile app options">Your Hyvä store is already fast. Now make it an app — without rebuilding it.</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Problem -->
        <div class="border border-neutral-200 rounded-card p-8 lg:p-10 bg-white">
          <p class="text-red-600 font-semibold text-sm uppercase tracking-wide mb-6">The problem with other approaches</p>
          <div class="space-y-6">
            {hyvaProblems.map((p) => (
              <div class="flex gap-3">
                <span class="flex-shrink-0 mt-1">
                  <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#DC2626"/><path d="M5.5 5.5L10.5 10.5M10.5 5.5L5.5 10.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/></svg>
                </span>
                <div>
                  <p class="font-display font-bold text-neutral-900 text-base mb-1">{p.title}</p>
                  <p class="text-neutral-500 text-sm leading-relaxed">{p.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Solution -->
        <div class="border-2 border-primary-600 rounded-card p-8 lg:p-10 bg-primary-50">
          <p class="text-primary-700 font-semibold text-sm uppercase tracking-wide mb-6">How MobiLoud is different</p>
          <div class="space-y-6">
            {hyvaSolutions.map((s) => (
              <div class="flex gap-3">
                <span class="flex-shrink-0 mt-1">
                  <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="8" fill="#047857"/><path d="M5 8L7 10L11 6" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <div>
                  <p class="font-display font-bold text-neutral-900 text-base mb-1">{s.title}</p>
                  <p class="text-neutral-500 text-sm leading-relaxed">{s.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="#lead-form-section" class="btn-primary cursor-pointer" style="cursor: pointer;">See the Difference for Yourself</a>
      </div>
    </Container>
  </section>

  <ValueProp />
  <CaseStudies />
  <DarkFeatures />
  <IntegrationsSection />
  <TestimonialsRow />

  <!-- Hyvä FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            Still have questions? Get a free preview and we'll walk you through everything.
          </p>
          <a href="#lead-form-section" class="btn-primary cursor-pointer text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {hyvaFaqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const triggers = document.querySelectorAll('.faq-trigger');

      triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          const index = (trigger as HTMLElement).dataset.faqIndex;
          const answer = document.querySelector(`[data-faq-answer="${index}"]`);
          const arrow = trigger.querySelector('.faq-arrow');
          const isOpen = answer?.classList.contains('open');

          // Close all
          document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
          document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
          document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

          // Toggle current
          if (!isOpen) {
            answer?.classList.add('open');
            arrow?.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  </script>

  <FinalCTA />
  <Footer />
</Layout>
