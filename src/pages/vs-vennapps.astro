---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import CompetitorHero from '../components/sections/CompetitorHero.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import CompetitorComparison from '../components/sections/CompetitorComparison.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import '../styles/global.css';

const comparisonRows = [
  {
    feature: 'Approach',
    competitor: 'Bespoke native app development agency. They build custom apps in Swift (iOS) and Kotlin (Android) for each client.',
    mobiloud: 'Builds on your existing site. Fully customizable app experience with automatic sync and full tech stack access.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Store rebuild',
    competitor: 'Your app is designed from scratch by their team, a separate experience from your website.',
    mobiloud: 'No rebuild needed. Your app is built on your existing codebase, with full flexibility to customize the experience.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Ongoing maintenance',
    competitor: 'App design and content are managed separately from your website via their CMS editor.',
    mobiloud: 'Update your site once. Your app syncs automatically.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Integrations',
    competitor: '50+ integrations via their proprietary middleware architecture.',
    mobiloud: 'Unlimited. Every tool on your website works in your app automatically.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Custom features',
    competitor: 'Fully bespoke development with a dedicated designer. High degree of customization, but requires their team for changes.',
    mobiloud: 'All custom features from your website carry over with no extra development.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Service model',
    competitor: 'White-glove managed service with dedicated designer and account manager. Monthly strategy sessions on Enterprise.',
    mobiloud: 'Fully managed on Corporate. Dedicated success manager, Slack support, regular meetings.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Pricing',
    competitor: 'From $499/mo (Essential) to $1,999/mo (Enterprise). Shopify-only. Premium pricing for bespoke development.',
    mobiloud: 'From $799/mo (Growth) to $1,499/mo (Corporate). No revenue share. Any platform.',
    competitorBad: false,
    mobiloudGood: true,
  },
];

const faqs = [
  {
    q: 'How is MobiLoud different from Venn Apps?',
    a: "Venn Apps is a premium agency that builds bespoke native apps from scratch using Swift and Kotlin, with a dedicated designer for each project. MobiLoud takes a different approach: we build on your existing site, so every integration, customization, and feature carries over automatically. You can also customize the app experience independently, with app-specific pages, layouts, and features. Both offer managed service, but MobiLoud doesn't require a separate app to be designed and built from scratch.",
  },
  {
    q: 'Venn Apps builds truly native apps. Is MobiLoud different?',
    a: "Venn Apps builds separate native codebases in Swift and Kotlin, which means your app is a completely separate product from your website. MobiLoud also delivers native iOS and Android apps, but they're powered by your existing website. The result is the same, native apps in the App Store and Google Play, but with MobiLoud you don't maintain two separate experiences or need a design team to update your app.",
  },
  {
    q: 'Is Venn Apps better for enterprise brands?',
    a: "Venn Apps positions itself for Shopify Plus brands wanting bespoke app design with dedicated designers. If your priority is a completely unique app experience that looks nothing like your website, that's their strength. If you want your website experience in a native app, with everything synced and one platform to manage, MobiLoud is the more practical choice. Many enterprise brands choose MobiLoud precisely because they don't want to manage a separate app.",
  },
  {
    q: 'How does pricing compare?',
    a: "Venn Apps' Enterprise plan is $1,999/mo for their full white-glove service. MobiLoud's Corporate plan is $1,499/mo and includes a dedicated success manager, Slack and phone support, regular strategy meetings, and hands-on launch support. MobiLoud also works with any platform, not just Shopify.",
  },
  {
    q: 'Does MobiLoud only work with Shopify?',
    a: "No. MobiLoud works with any platform: Shopify, WooCommerce, Magento, BigCommerce, custom platforms, or any website that runs in a browser. Venn Apps is Shopify-only.",
  },
  {
    q: 'Will all my integrations work?',
    a: "Yes. Because your app is powered by your live website, every tool and integration you already use works automatically. Venn Apps supports 50+ integrations via their proprietary middleware. With MobiLoud, if it works on your site, it works in your app, no configuration needed.",
  },
  {
    q: 'How long does it take to launch?',
    a: "About 30 days from sign-up to launch. Venn Apps quotes about 4 weeks as well, but their process involves bespoke design work. With MobiLoud, your app is built from your existing website, so there's no design phase to manage.",
  },
  {
    q: 'What kind of support do I get?',
    a: "On MobiLoud's Corporate plan, you get a dedicated Customer Success Manager, Slack and phone support, weekly meetings during launch, and ongoing strategy guidance. We handle all platform and OS updates, app store compliance, and help optimize your engagement flows.",
  },
  {
    q: 'What is your cancellation policy?',
    a: "You can cancel anytime with 30 days written notice if you're not on a contract. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid. Setup fees are non-refundable.",
  },
];
---

<Layout
  title="MobiLoud vs Venn Apps - A Managed App Without Rebuilding Your Store"
  description="Compare MobiLoud and Venn Apps. MobiLoud builds on your existing site to deliver a fully customizable native app with automatic sync and managed service."
>
  <Nav />

  <CompetitorHero
    competitor="Venn Apps"
    headline="Your Store as a Native App. No Bespoke Build Needed."
    subhead="Venn Apps builds custom native apps from scratch with dedicated designers. MobiLoud builds on your existing site to deliver a fully customizable native app, with automatic sync, full tech stack access, and a team that handles everything."
    checklist={[
      'No separate app to design, build, and maintain',
      'No managing two platforms. Your site and app stay in sync.',
      'Works with any platform, not just Shopify.',
    ]}
  />

  <LogoMarquee />

  <CaseStudies />

  <CompetitorComparison
    competitor="Venn Apps"
    rows={comparisonRows}
  />

  <DarkFeatures />

  <IntegrationsSection />

  <TestimonialsRow />

  <!-- Competitor-specific FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            See how your store looks as a MobiLoud app. Free preview, no commitment.
          </p>
          <a href="#lead-form-section" class="btn-primary text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {faqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
