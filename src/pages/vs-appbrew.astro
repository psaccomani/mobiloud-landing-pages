---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import CompetitorHero from '../components/sections/CompetitorHero.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import CompetitorComparison from '../components/sections/CompetitorComparison.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import '../styles/global.css';

const comparisonRows = [
  {
    feature: 'Approach',
    competitor: 'AI-native React Native app builder. You build a separate native app through their platform.',
    mobiloud: 'Your existing website becomes your app. No separate platform to manage.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Store rebuild',
    competitor: 'You build your app in their editor. It\'s a separate native app, not connected to your website.',
    mobiloud: 'No rebuild. Your live site powers the app, including all custom code and design.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Ongoing maintenance',
    competitor: 'Products sync from Shopify, but app design and content are managed separately.',
    mobiloud: 'Update your site once. Your app syncs automatically.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Integrations',
    competitor: '100+ native integrations through their platform.',
    mobiloud: 'Unlimited. Every tool on your website works in your app automatically.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Custom features',
    competitor: 'AI-powered features including Milo assistant, AI Concierge, and AI Skin Analyzer.',
    mobiloud: 'All custom features from your website carry over with no extra development.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Service model',
    competitor: 'Dedicated success manager and 24/7 Slack support on Pro plan.',
    mobiloud: 'Fully managed on Corporate. Dedicated success manager, Slack support, regular meetings.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Pricing',
    competitor: 'From $499/mo (Pro). Enterprise is custom pricing. Performance-based charges may apply.',
    mobiloud: 'From $799/mo (Growth) to $1,499/mo (Corporate). Flat fee, no revenue share.',
    competitorBad: false,
    mobiloudGood: true,
  },
];

const faqs = [
  {
    q: 'What makes MobiLoud\'s approach different?',
    a: 'Appbrew builds a separate native app using React Native — it\'s a standalone product you design and manage through their platform. MobiLoud takes a different approach: your existing website becomes your app. Everything you already have — design, integrations, custom code — works automatically. No rebuilding, no managing two platforms.',
  },
  {
    q: 'Do I need to rebuild my store?',
    a: "No. With MobiLoud, there's nothing to rebuild. Your existing website becomes your app. All your custom code, third-party integrations, and design elements carry over automatically. With Appbrew, you build a separate native app through their editor, which means creating and managing a second platform alongside your website.",
  },
  {
    q: 'How does migration work?',
    a: "It's a simple process. We build your new app from your existing website — no content migration, no data transfer, no rebuilding. The new app is submitted as an update to your existing App Store and Google Play listings, so you keep your reviews and download history. Your current app stays live until the new one is approved. The whole process takes about 30 days.",
  },
  {
    q: 'What about pricing and hidden fees?',
    a: "MobiLoud charges a flat monthly fee: $799/mo for Growth, $1,499/mo for Corporate. No revenue share, no success fees. Appbrew's Pro plan starts at $499/mo, but their pricing notes mention potential performance-based charges on top of the subscription. With MobiLoud, your price stays the same regardless of how much revenue your app generates.",
  },
  {
    q: 'Will all my integrations work?',
    a: "Yes. Because your app is powered by your live website, every tool and integration you already use works automatically. There's no compatibility list to check and no integrations to configure separately. Appbrew offers 100+ native integrations, but with MobiLoud, if it works on your site, it works in your app.",
  },
  {
    q: 'Does MobiLoud work with platforms other than Shopify?',
    a: "Yes. MobiLoud works with any web platform — Shopify, WooCommerce, Magento, BigCommerce, custom-built sites, and more. Appbrew is Shopify-only. If you're on a different platform or plan to migrate in the future, MobiLoud doesn't lock you into a single ecommerce provider.",
  },
  {
    q: 'What kind of support do I get?',
    a: "On MobiLoud's Corporate plan, you get a dedicated Customer Success Manager, Slack and phone support, weekly meetings during launch, and ongoing strategy guidance. We monitor performance, handle all platform and OS updates, and help you optimize push notifications and engagement flows. Appbrew also offers dedicated success managers and 24/7 Slack support on their Pro plan.",
  },
  {
    q: 'How long does it take to launch?',
    a: "About 30 days from sign-up to launch. Our team handles everything: app development, custom graphics, app store submissions, and approval monitoring. You don't need to do any technical work.",
  },
  {
    q: 'What is your cancellation policy?',
    a: "You can cancel anytime with 30 days written notice if you're not on a contract. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid. Setup fees are non-refundable.",
  },
];
---

<Layout
  title="MobiLoud vs Appbrew — A Managed App Without Rebuilding Your Store"
  description="Compare MobiLoud and Appbrew. MobiLoud turns your existing website into a native app with fully managed service. No rebuilding, no separate platform to manage."
>
  <Nav />

  <CompetitorHero
    competitor="Appbrew"
    headline="Your Store as a Native App. No Rebuild. No Second Platform."
    subhead="Appbrew is a strong, AI-powered app builder for Shopify stores. But it still requires building and managing a separate app. MobiLoud turns your existing website into a native app — everything you have carries over, and our team manages it all."
    checklist={[
      'No rebuilding your store in a separate platform',
      'Works with any web platform, not just Shopify.',
      'Fully managed service with a dedicated team on your side.',
    ]}
  />

  <LogoMarquee />

  <CaseStudies />

  <CompetitorComparison
    competitor="Appbrew"
    rows={comparisonRows}
  />

  <DarkFeatures />

  <IntegrationsSection />

  <TestimonialsRow />

  <!-- Competitor-specific FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            See how your store looks as a MobiLoud app. Free preview, no commitment.
          </p>
          <a href="https://www.mobiloud.com/demo" class="btn-primary text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {faqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
