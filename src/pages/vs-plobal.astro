---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import CompetitorHero from '../components/sections/CompetitorHero.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import CompetitorComparison from '../components/sections/CompetitorComparison.astro';
import PricingAttack from '../components/sections/PricingAttack.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import '../styles/global.css';

const comparisonRows = [
  {
    feature: 'Approach',
    competitor: 'Drag-and-drop app builder with Code Blocks for advanced customization.',
    mobiloud: 'Your existing website becomes your app. No separate platform to manage.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Store rebuild',
    competitor: 'You build your app in their editor using pre-built layouts and templates.',
    mobiloud: 'No rebuild. Your live site powers the app, including all custom code and design.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Ongoing maintenance',
    competitor: 'Products sync from Shopify, but app design and content are managed separately.',
    mobiloud: 'Update your site once. Your app syncs automatically.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Integrations',
    competitor: '30+ supported integrations through their platform.',
    mobiloud: 'Unlimited. Every tool on your website works in your app automatically.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Custom features',
    competitor: 'Code Blocks for HTML/CSS/JavaScript customization within their builder.',
    mobiloud: 'All custom features from your website carry over with no extra development.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Service model',
    competitor: 'Dedicated success managers on Enterprise ($1,199/mo) only. Email and chat on lower tiers.',
    mobiloud: 'Fully managed on Corporate. Dedicated success manager, Slack support, regular meetings.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Pricing',
    competitor: 'From $199/mo (Growth) + 3% revenue share, to $1,199/mo (Enterprise) + 1% revenue share.',
    mobiloud: 'From $799/mo (Growth) to $1,499/mo (Corporate). No revenue share, no success fees.',
    competitorBad: true,
    mobiloudGood: true,
  },
];

const pricingExamples = [
  {
    monthlyRevenue: '$25,000',
    competitorFee: '$750',
    competitorTotal: '$949/mo',
    mobiloudTotal: '$799/mo',
  },
  {
    monthlyRevenue: '$50,000',
    competitorFee: '$1,500',
    competitorTotal: '$1,699/mo',
    mobiloudTotal: '$799/mo',
  },
  {
    monthlyRevenue: '$100,000',
    competitorFee: '$3,000',
    competitorTotal: '$3,199/mo',
    mobiloudTotal: '$1,499/mo',
  },
  {
    monthlyRevenue: '$250,000',
    competitorFee: '$7,500',
    competitorTotal: '$7,699/mo',
    mobiloudTotal: '$1,499/mo',
  },
];

const faqs = [
  {
    q: 'How is MobiLoud different from app builders?',
    a: 'App builders like Plobal Apps require you to design and manage your app in a separate drag-and-drop editor. MobiLoud takes a different approach: your existing website becomes your app. Everything you already have — design, integrations, custom code — works automatically. No rebuilding, no managing two platforms.',
  },
  {
    q: 'Do I need to rebuild my store?',
    a: "No. With MobiLoud, there's nothing to rebuild. Your existing website becomes your app. All your custom code, third-party integrations, and design elements carry over automatically. With Plobal Apps, you build your app in their editor using templates and pre-built layouts.",
  },
  {
    q: 'How does migration work?',
    a: "It's a simple process. We build your new app from your existing website — no content migration, no data transfer, no rebuilding. The new app is submitted as an update to your existing App Store and Google Play listings, so you keep your reviews and download history. Your current app stays live until the new one is approved. The whole process takes about 30 days.",
  },
  {
    q: 'What about pricing and hidden fees?',
    a: "MobiLoud has simple monthly pricing starting at $799/mo for Growth and $1,499/mo for Corporate. No revenue share, no success fees, ever. Plobal Apps charges a 1-3% revenue share on top of their monthly subscription ($199-$1,199/mo). On their Growth plan at $199/mo with $50,000 in monthly app revenue, you'd pay an additional $1,500/mo in fees, making the real cost $1,699/mo. MobiLoud never takes a cut of your revenue.",
  },
  {
    q: 'Will all my integrations work?',
    a: "Yes. Because your app is powered by your live website, every tool and integration you already use works automatically. There's no compatibility list to check and no integrations to configure separately. Plobal Apps supports 30+ integrations through their platform, but with MobiLoud, if it works on your site, it works in your app.",
  },
  {
    q: 'What kind of support do I get?',
    a: "On MobiLoud's Corporate plan, you get a dedicated Customer Success Manager, Slack and phone support, weekly meetings during launch, and ongoing strategy guidance. We monitor performance, handle all platform and OS updates, and help you optimize push notifications and engagement flows. Plobal Apps offers dedicated success managers only on their Enterprise plan ($1,199/mo).",
  },
  {
    q: 'How long does it take to launch?',
    a: "About 30 days from sign-up to launch. Our team handles everything: app development, custom graphics, app store submissions, and approval monitoring. You don't need to do any technical work.",
  },
  {
    q: 'How does the total cost compare as my app grows?',
    a: "MobiLoud has straightforward monthly pricing with no revenue share. Plobal Apps charges a 1-3% revenue share on in-app sales. As your app succeeds and revenue grows, Plobal's costs grow with it. At $100,000/mo in app revenue on Plobal's Growth plan, you'd pay $199 + $3,000 = $3,199/mo. MobiLoud never charges a percentage of your sales.",
  },
  {
    q: 'What is your cancellation policy?',
    a: "You can cancel anytime with 30 days written notice if you're not on a contract. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid. Setup fees are non-refundable.",
  },
];
---

<Layout
  title="MobiLoud vs Plobal Apps — Simple Pricing, No Revenue Share"
  description="Compare MobiLoud and Plobal Apps. MobiLoud turns your existing website into a native app with simple pricing and no revenue share. No rebuilding, fully managed."
>
  <Nav />

  <CompetitorHero
    competitor="Plobal Apps"
    headline="Your Store as a Native App. Simple Pricing. No Revenue Share."
    subhead="Plobal Apps is a solid app builder for Shopify stores, but charges 1-3% revenue share on top of their subscription. MobiLoud turns your existing website into a native app with simple monthly pricing and no revenue share, no matter how much your app earns."
    checklist={[
      'No revenue share. We never take a cut of your sales.',
      'No rebuilding your store in a separate editor.',
      'Fully managed service with a dedicated team on your side.',
    ]}
  />

  <LogoMarquee />

  <CaseStudies />

  <CompetitorComparison
    competitor="Plobal Apps"
    rows={comparisonRows}
  />

  <PricingAttack
    competitor="Plobal Apps"
    feeDescription="Plobal Apps charges a 1-3% revenue share on all in-app sales, on top of their monthly subscription. Here's how that adds up compared to MobiLoud's simple pricing."
    examples={pricingExamples}
  />

  <DarkFeatures />

  <IntegrationsSection />

  <TestimonialsRow />

  <!-- Competitor-specific FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            See how your store looks as a MobiLoud app. Free preview, no commitment.
          </p>
          <a href="#lead-form-section" class="btn-primary text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {faqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
