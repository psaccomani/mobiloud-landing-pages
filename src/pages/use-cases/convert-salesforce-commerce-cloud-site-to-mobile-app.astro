        <td class="mob" data-label="MobiLoud">Yes (submission handled)</td>
        <td data-label="PWA">Limited/none</td>
        <td data-label="Cross-Platform">Yes (DIY submission)</td>
        <td data-label="Headless">Yes (depends on chosen mobile frontend)</td>
      </tr>
      <tr>
        <th scope="row">Native features & push</th>
        <td class="mob" data-label="MobiLoud">Full native push; tabs, deep links, navigation & splash screens</td>
        <td data-label="PWA">Limited device access; web push</td>
        <td data-label="Cross-Platform">Near-native access to device features & push</td>
