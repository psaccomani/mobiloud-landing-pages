---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/sections/Nav.astro';
import DarkHero from '../../components/sections/DarkHero.astro';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import ComparisonSection from '../../components/sections/ComparisonSection.astro';
import ValueProp from '../../components/sections/ValueProp.astro';
import CaseStudies from '../../components/sections/CaseStudies.astro';
import DarkFeatures from '../../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../../components/sections/TestimonialsRow.astro';
import FAQSidebar from '../../components/sections/FAQSidebar.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import Footer from '../../components/sections/Footer.astro';
import '../../styles/global.css';

const faqs = [];
---

<Layout
  title="MobiLoud - How to Turn Your Volusion Store Into a Native Mobile App"
  description="Launching a mobile app is a great way for growing ecommerce brands to increase retention and LTV. Learn when MobiLoud is the best solution to make it happen."
>
  <Nav />
  <DarkHero platform="Volusion" />
  <LogoMarquee />
  <ComparisonSection />
  <ValueProp heading="From your Volusion store to the App Store in 3 steps" />
  <CaseStudies />
  <DarkFeatures />
  <IntegrationsSection />
  <TestimonialsRow />
  <FAQSidebar faqs={faqs} />
  <FinalCTA />
  <Footer />
</Layout>