---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/sections/Nav.astro';
import DarkHero from '../../components/sections/DarkHero.astro';
import LogoMarquee from '../../components/sections/LogoMarquee.astro';
import ComparisonSection from '../../components/sections/ComparisonSection.astro';
import ValueProp from '../../components/sections/ValueProp.astro';
import CaseStudies from '../../components/sections/CaseStudies.astro';
import DarkFeatures from '../../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../../components/sections/TestimonialsRow.astro';
import FAQSidebar from '../../components/sections/FAQSidebar.astro';
import FinalCTA from '../../components/sections/FinalCTA.astro';
import Footer from '../../components/sections/Footer.astro';
import '../../styles/global.css';

const faqs = [{ question: "Do I need developers or coding knowledge?", answer: "No. MobiLoud is a fully managed service. We handle the entire process: app build, App Store and Google Play submission, and ongoing maintenance. You don't need any technical resources on your end." }, { question: "Will my Shopify apps and integrations work in the mobile app?", answer: "Yes. Because the app runs your actual Shopify website, every app and integration works automatically. Loyalty programs, review widgets, subscription tools, custom scripts: if it's on your website, it's in your app." }, { question: "How does the app stay in sync with my Shopify store?", answer: "The app delivers your live website, so any change you make (new products, updated collections, homepage redesigns) is reflected in real time. No manual syncing required." }, { question: "How much does it cost, and how long until my app is live?", answer: "Pricing starts at $799/month, with no revenue share, no per-transaction fees. There's one-time setup fee on top of this (we'll give you an exact quote depending on your specific requirements). Most stores go live in around 30 days. We handle the entire process, from build to QA to app store submission and launch coordination." }];
---

<Layout
  title="MobiLoud - How to Convert Your Shopify Store to a Mobile App (2026 Guide)"
  description="You don't need to rebuild your Shopify store to launch a native app. MobiLoud converts your existing store, with all its integrations, customizations, and checkout flow, into iOS and Android apps in about 30 days. One platform to manage, not two."
>
  <Nav />
  <DarkHero />
  <LogoMarquee />
  <ComparisonSection />
  <ValueProp heading="From your Shopify store to the App Store in 3 steps" />
  <CaseStudies />
  <DarkFeatures />
  <IntegrationsSection />
  <TestimonialsRow />
  <FAQSidebar faqs={faqs} />
  <FinalCTA />
  <Footer />
</Layout>