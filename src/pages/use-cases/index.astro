---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/sections/Nav.astro';
import Footer from '../../components/sections/Footer.astro';
import '../../styles/global.css';

const useCasePages = Object.keys(import.meta.glob('./*.astro', { eager: true }));

const platforms = useCasePages
  .filter((path) => !path.includes('index.astro'))
  .map((path) => {
    const name = path.replace('./', '').replace('.astro', '').replace('-', ' ').replace(/\b\w/g, (c) => c.toUpperCase());
    const slug = path.replace('./', '').replace('.astro', '');
    return { slug, name };
  })
  .sort((a, b) => a.name.localeCompare(b.name));
---

<Layout
  title="MobiLoud - Platform Mobile App Guides"
  description="Learn how to convert your ecommerce platform into a mobile app. Browse our guides for Shopify, WooCommerce, Magento, and 100+ other platforms."
>
  <Nav />

  <section class="py-20 md:py-32 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">Platform Mobile App Guides</h1>
      <p class="text-xl text-slate-600 mb-8">Learn how to convert your ecommerce platform into a mobile app. Browse our guides for Shopify, WooCommerce, Magento, and 100+ other platforms.</p>
    </div>
  </section>

  <section class="py-16 px-4 bg-slate-50">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {platforms.map((p) => (
          <a href={`/pages/use-cases/${p.slug}`} class="block p-4 bg-white rounded-lg border border-slate-200 hover:border-primary-500 hover:shadow-md transition-all text-center">
            <span class="font-semibold text-slate-700">{p.name}</span>
          </a>
        ))}
      </div>
      <p class="text-center text-slate-500 mt-8">{platforms.length} platforms</p>
    </div>
  </section>

  <Footer />
</Layout>
