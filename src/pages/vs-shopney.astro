---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import CompetitorHero from '../components/sections/CompetitorHero.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import CompetitorComparison from '../components/sections/CompetitorComparison.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import '../styles/global.css';

const comparisonRows = [
  {
    feature: 'Approach',
    competitor: 'Drag-and-drop app builder. You design your app in their editor, separate from your website.',
    mobiloud: 'Your existing website becomes your app. No separate platform to manage.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Store rebuild',
    competitor: 'You recreate your store layout using their drag-and-drop editor and theme templates.',
    mobiloud: 'No rebuild. Your live site powers the app, including all custom code and design.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Ongoing maintenance',
    competitor: 'Changes to your website and app are managed separately.',
    mobiloud: 'Update your site once. Your app syncs automatically.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Integrations',
    competitor: '60+ supported integrations via their platform.',
    mobiloud: 'Unlimited. Every tool on your website works in your app automatically.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Custom features',
    competitor: 'Customization limited to their editor capabilities and theme options.',
    mobiloud: 'All custom features from your website carry over with no extra development.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Service model',
    competitor: 'Self-service with 24/7 live chat support. Dedicated success manager on Enterprise ($1,299/mo).',
    mobiloud: 'Fully managed on Corporate. Dedicated success manager, Slack support, regular meetings.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Pricing',
    competitor: 'From $149/mo (Silver) to $599/mo (Platinum). Enterprise from $1,299/mo. No revenue share.',
    mobiloud: 'From $799/mo (Growth) to $1,499/mo (Corporate). Flat fee, no revenue share.',
    competitorBad: false,
    mobiloudGood: true,
  },
];

const faqs = [
  {
    q: 'How is MobiLoud different from app builders?',
    a: 'App builders like Shopney require you to design and manage your app in a separate drag-and-drop editor, apart from your website. MobiLoud takes a different approach: your existing website becomes your app. Everything you already have — design, integrations, custom code — works automatically. No rebuilding, no managing two platforms.',
  },
  {
    q: 'Do I need to rebuild my store?',
    a: "No. With MobiLoud, there's nothing to rebuild. Your existing website becomes your app. All your custom code, third-party integrations, and design elements carry over automatically. With Shopney, you recreate your store layout in their editor using their themes and design elements.",
  },
  {
    q: 'How does migration work?',
    a: "It's a simple process. We build your new app from your existing website — no content migration, no data transfer, no rebuilding. The new app is submitted as an update to your existing App Store and Google Play listings, so you keep your reviews and download history. Your current app stays live until the new one is approved. The whole process takes about 30 days.",
  },
  {
    q: 'What about pricing and hidden fees?',
    a: "MobiLoud charges a flat monthly fee: $799/mo for Growth, $1,499/mo for Corporate. No revenue share, no success fees. Shopney also uses flat pricing (from $149/mo to $1,299/mo) with no commissions, so both platforms are transparent on pricing. The difference is what you get: MobiLoud's Corporate plan includes a dedicated success manager, Slack and phone support, and regular strategy meetings — a fully managed service rather than a self-service platform.",
  },
  {
    q: 'Will all my integrations work?',
    a: "Yes. Because your app is powered by your live website, every tool and integration you already use works automatically. There's no compatibility list to check and no integrations to configure separately. Shopney supports 60+ integrations through their platform, but with MobiLoud, if it works on your site, it works in your app.",
  },
  {
    q: 'What kind of support do I get?',
    a: "On MobiLoud's Corporate plan, you get a dedicated Customer Success Manager, Slack and phone support, weekly meetings during launch, and ongoing strategy guidance. We monitor performance, handle all platform and OS updates, and help you optimize push notifications and engagement flows. Shopney offers 24/7 live chat on all plans and a dedicated success manager on their Enterprise tier.",
  },
  {
    q: 'What makes MobiLoud\'s approach different?',
    a: "Shopney is a well-regarded app builder — you design your app in their editor using templates and drag-and-drop tools. MobiLoud wraps your existing website into a native app, so your entire site experience, including any custom code, third-party tools, and design work, carries over automatically. You manage one platform (your website) instead of two.",
  },
  {
    q: 'How long does it take to launch?',
    a: "About 30 days from sign-up to launch. Our team handles everything: app development, custom graphics, app store submissions, and approval monitoring. You don't need to do any technical work. Shopney advertises launch in about 5 days, though that's for their self-service builder where you do the design work yourself.",
  },
  {
    q: 'What is your cancellation policy?',
    a: "You can cancel anytime with 30 days written notice if you're not on a contract. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid. Setup fees are non-refundable.",
  },
];
---

<Layout
  title="MobiLoud vs Shopney — A Managed App Without Rebuilding Your Store"
  description="Compare MobiLoud and Shopney. MobiLoud turns your existing website into a native app with fully managed service. No rebuilding, no separate platform to manage."
>
  <Nav />

  <CompetitorHero
    competitor="Shopney"
    headline="Your Store as a Native App. Fully Managed. No DIY."
    subhead="Shopney is a well-rated app builder with affordable plans, but it requires you to design and manage your app yourself in their editor. MobiLoud takes a different approach: your existing site becomes your app, and our team handles everything."
    checklist={[
      'No redesigning your store in a separate editor',
      'No managing two platforms. Your site and app stay in sync.',
      'Fully managed service with a dedicated team on your side.',
    ]}
  />

  <LogoMarquee />

  <CaseStudies />

  <CompetitorComparison
    competitor="Shopney"
    rows={comparisonRows}
  />

  <DarkFeatures />

  <IntegrationsSection />

  <TestimonialsRow />

  <!-- Competitor-specific FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            See how your store looks as a MobiLoud app. Free preview, no commitment.
          </p>
          <a href="https://www.mobiloud.com/demo" class="btn-primary text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {faqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
