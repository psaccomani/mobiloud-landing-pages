---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import CompetitorHero from '../components/sections/CompetitorHero.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import CompetitorComparison from '../components/sections/CompetitorComparison.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import '../styles/global.css';

const comparisonRows = [
  {
    feature: 'Approach',
    competitor: 'No-code drag-and-drop app builder. You design and manage your app in their editor with pre-built themes.',
    mobiloud: 'Builds on your existing site. Fully customizable app experience with automatic sync and full tech stack access.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Store rebuild',
    competitor: 'You recreate your store using their design blocks and customizable themes.',
    mobiloud: 'No rebuild needed. Your app is built on your existing codebase, with full flexibility to customize the experience.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Ongoing maintenance',
    competitor: 'Your website and app are managed separately in two different systems.',
    mobiloud: 'Update your site once. Your app syncs automatically.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Integrations',
    competitor: '30+ supported integrations via their platform.',
    mobiloud: 'Unlimited. Every tool on your website works in your app automatically.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Custom features',
    competitor: 'Customization limited to their drag-and-drop blocks and theme options. AR available on Premium.',
    mobiloud: 'All custom features from your website carry over with no extra development.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Service model',
    competitor: 'Primarily self-service. Setup assistance and email support. Dedicated support on Custom plan only.',
    mobiloud: 'Fully managed on Corporate. Dedicated success manager, Slack support, regular meetings.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Pricing',
    competitor: 'From $99/mo (Starter) to $249/mo (Premium). Custom plan for enterprise. Shopify-only.',
    mobiloud: 'From $799/mo (Growth) to $1,499/mo (Corporate). No revenue share. Any platform.',
    competitorBad: false,
    mobiloudGood: true,
  },
];

const faqs = [
  {
    q: 'How is MobiLoud different from MageNative?',
    a: 'MageNative is a no-code Shopify app builder where you design your app using drag-and-drop blocks and pre-built themes, separate from your website. MobiLoud takes a different approach: we build on your existing site, so every integration, customization, and feature you already have works in the app automatically. You can also customize the app experience independently, with app-specific pages, layouts, and features, all built on the same codebase.',
  },
  {
    q: 'MageNative is much cheaper. Why would I pay more for MobiLoud?',
    a: "MageNative starts at $99/mo, but it's a self-service platform where you build and manage the app yourself. MobiLoud's Corporate plan at $1,499/mo includes a dedicated success manager, Slack and phone support, regular strategy meetings, and hands-on launch support. You're getting a team that builds, launches, and maintains your app. There's also no store rebuild needed and no second platform to manage ongoing.",
  },
  {
    q: 'Do I need to rebuild my store?',
    a: "No. MobiLoud builds on your existing site, so there's nothing to recreate. All your custom code, design, and integrations carry over automatically. You can also add app-specific customizations, like a dedicated app homepage or simplified navigation, using standard web development. MageNative requires recreating your store in their editor using their design blocks and themes.",
  },
  {
    q: 'Does MobiLoud only work with Shopify?',
    a: "No. MobiLoud works with any platform: Shopify, WooCommerce, Magento, BigCommerce, custom platforms, or any website that runs in a browser. MageNative is Shopify-only. If you're on a different platform or plan to migrate in the future, MobiLoud works regardless.",
  },
  {
    q: 'Will all my integrations work?',
    a: "Yes. Because your app is powered by your live website, every tool and integration you already use works automatically. There's no compatibility list to check. MageNative supports 30+ integrations through their platform, but you're limited to what they've built connectors for.",
  },
  {
    q: 'How long does it take to launch?',
    a: "About 30 days from sign-up to launch. Our team handles everything: app development, custom graphics, app store submissions, and approval monitoring. MageNative advertises a 30-minute setup, but that's for their self-service builder where you do all the design and configuration work yourself.",
  },
  {
    q: 'What kind of support do I get?',
    a: "On MobiLoud's Corporate plan, you get a dedicated Customer Success Manager, Slack and phone support, weekly meetings during launch, and ongoing strategy guidance. We handle all platform and OS updates, app store compliance, and help optimize your engagement flows.",
  },
  {
    q: 'What is your cancellation policy?',
    a: "You can cancel anytime with 30 days written notice if you're not on a contract. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid. Setup fees are non-refundable.",
  },
];
---

<Layout
  title="MobiLoud vs MageNative - A Managed App Without Rebuilding Your Store"
  description="Compare MobiLoud and MageNative. MobiLoud builds on your existing site to deliver a fully customizable native app with automatic sync and managed service."
>
  <Nav />

  <CompetitorHero
    competitor="MageNative"
    headline="Your Store as a Native App. Fully Managed. No DIY."
    subhead="MageNative is a budget-friendly app builder, but it requires you to design and manage your app yourself in their editor. MobiLoud builds on your existing site to deliver a fully customizable native app, with automatic sync, full tech stack access, and a team that handles everything."
    checklist={[
      'No rebuilding your store in a drag-and-drop editor',
      'No managing two platforms. Your site and app stay in sync.',
      'Works with any platform, not just Shopify.',
    ]}
  />

  <LogoMarquee />

  <CaseStudies />

  <CompetitorComparison
    competitor="MageNative"
    rows={comparisonRows}
  />

  <DarkFeatures />

  <IntegrationsSection />

  <TestimonialsRow />

  <!-- Competitor-specific FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            See how your store looks as a MobiLoud app. Free preview, no commitment.
          </p>
          <a href="#lead-form-section" class="btn-primary text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {faqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
