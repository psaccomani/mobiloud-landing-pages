---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/sections/Nav.astro';
import CompetitorHero from '../components/sections/CompetitorHero.astro';
import LogoMarquee from '../components/sections/LogoMarquee.astro';
import CompetitorComparison from '../components/sections/CompetitorComparison.astro';
import CaseStudies from '../components/sections/CaseStudies.astro';
import DarkFeatures from '../components/sections/DarkFeatures.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import TestimonialsRow from '../components/sections/TestimonialsRow.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
import Footer from '../components/sections/Footer.astro';
import Container from '../components/ui/Container.astro';
import '../styles/global.css';

const comparisonRows = [
  {
    feature: 'Approach',
    competitor: 'Drag-and-drop app builder. You design and manage your app in their editor.',
    mobiloud: 'Builds on your existing site. Fully customizable app experience with automatic sync and full tech stack access.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Store rebuild',
    competitor: 'You recreate your store layout in their block editor, separate from your website.',
    mobiloud: 'No rebuild needed. Your app is built on your existing codebase, with full flexibility to customize the experience.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Ongoing maintenance',
    competitor: 'Changes to your website and app are managed separately.',
    mobiloud: 'Update your site once. Your app syncs automatically.',
    competitorBad: true,
    mobiloudGood: true,
  },
  {
    feature: 'Integrations',
    competitor: '80+ supported integrations via their platform.',
    mobiloud: 'Unlimited. Every tool on your website works in your app automatically.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Custom features',
    competitor: 'Custom Blocks (React-based) for advanced customization. AI add-on available at $250/mo.',
    mobiloud: 'All custom features from your website carry over with no extra development.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Service model',
    competitor: 'Primarily self-service. Dedicated account manager on Enterprise plan.',
    mobiloud: 'Fully managed on Corporate. Dedicated success manager, Slack support, regular meetings.',
    competitorBad: false,
    mobiloudGood: true,
  },
  {
    feature: 'Pricing',
    competitor: 'From $200/mo + 1.75-2.5% success fee on in-app sales. Enterprise from $1,000/mo.',
    mobiloud: 'From $799/mo (Growth) to $1,499/mo (Corporate). No revenue share.',
    competitorBad: false,
    mobiloudGood: true,
  },
];

const faqs = [
  {
    q: 'How is MobiLoud different from app builders?',
    a: 'App builders like Tapcart require you to design and manage your app in a separate editor, apart from your website. MobiLoud takes a different approach: we build on your existing site, so every integration, customization, and feature you already have works in the app automatically. You can also customize the app experience independently, with app-specific pages, layouts, and features, all built on the same codebase.',
  },
  {
    q: 'How does MobiLoud\'s pricing work?',
    a: "MobiLoud has simple monthly pricing with no revenue share: Growth at $799/mo and Corporate at $1,499/mo. Tapcart's base prices are lower, but they also charge a 1.75-2.5% success fee on in-app sales, which adds up as your app revenue grows. MobiLoud's Corporate plan includes a dedicated success manager, Slack and phone support, regular strategy meetings, and hands-on launch support. You're getting a team that builds, launches, and maintains your app, not a platform you manage yourself.",
  },
  {
    q: 'Do I need to rebuild my store?',
    a: "No. MobiLoud builds on your existing site, so there's nothing to recreate. All your custom code, integrations, and design carry over automatically. You can also add app-specific customizations, like a dedicated app homepage or simplified navigation, using standard web development. Unlike Tapcart, where you recreate your store in their editor.",
  },
  {
    q: 'How does migration work?',
    a: "It's a simple process. We build your new app from your existing website — no content migration, no data transfer, no rebuilding. The new app is submitted as an update to your existing App Store and Google Play listings, so you keep your reviews and download history. Your current app stays live until the new one is approved. The whole process takes about 30 days.",
  },
  {
    q: 'How long does it take to launch?',
    a: "About 30 days from sign-up to launch. Our team handles everything: app development, custom graphics, app store submissions, and approval monitoring. You don't need to do any technical work.",
  },
  {
    q: 'Will all my integrations work?',
    a: "Yes. Because your app is powered by your live website, every tool and integration you already use works automatically. There's no compatibility list to check and no integrations to configure separately.",
  },
  {
    q: 'What kind of support do I get after launch?',
    a: "On Corporate, you get a dedicated Customer Success Manager, Slack and phone support, weekly meetings during launch, and ongoing strategy guidance. We monitor performance, handle all platform and OS updates, and help you optimize push notifications and engagement flows.",
  },
  {
    q: 'What is your cancellation policy?',
    a: "You can cancel anytime with 30 days written notice if you're not on a contract. If your app is rejected by Apple or Google due to a MobiLoud platform-specific issue, we will refund subscription fees paid. Setup fees are non-refundable.",
  },
];
---

<Layout
  title="MobiLoud vs Tapcart — A Managed App Without Rebuilding Your Store"
  description="Compare MobiLoud and Tapcart. MobiLoud builds on your existing site to deliver a fully customizable native app with automatic sync and managed service."
>
  <Nav />

  <CompetitorHero
    competitor="Tapcart"
    headline="Your Store as a Native App. No Rebuilding. No DIY."
    subhead="Tapcart is a great app builder, but it requires you to design and manage your app separately from your website. MobiLoud builds on your existing site to deliver a fully customizable native app, with automatic sync, full tech stack access, and a team that handles everything."
    checklist={[
      'No rebuilding your store in a separate editor',
      'No managing two platforms. Your site and app stay in sync.',
      'Fully managed service with a dedicated team on your side.',
    ]}
  />

  <LogoMarquee />

  <CaseStudies />

  <CompetitorComparison
    competitor="Tapcart"
    rows={comparisonRows}
  />

  <DarkFeatures />

  <IntegrationsSection />

  <TestimonialsRow />

  <!-- Competitor-specific FAQ -->
  <section class="py-20 bg-background">
    <Container>
      <div class="grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-12 lg:gap-16">
        <!-- Left sidebar -->
        <div class="lg:sticky lg:top-24 lg:self-start">
          <h3 class="font-display text-display-4 text-primary-700 mb-4">Your questions, answered.</h3>
          <p class="text-neutral-600 text-base leading-relaxed mb-6">
            See how your store looks as a MobiLoud app. Free preview, no commitment.
          </p>
          <a href="#lead-form-section" class="btn-primary text-sm !py-2.5 !px-5">Get Your Free Preview</a>
        </div>

        <!-- Right: FAQ accordion -->
        <div class="space-y-0">
          {faqs.map((faq, i) => (
            <div class="border-b border-neutral-200">
              <button
                class="faq-trigger w-full flex items-center justify-between py-5 text-left cursor-pointer group"
                aria-expanded="false"
                data-faq-index={i}
              >
                <span class="font-display font-semibold text-neutral-900 text-base pr-4 group-hover:text-primary-700 transition-colors">{faq.q}</span>
                <svg class="faq-arrow flex-shrink-0 w-5 h-5 text-neutral-400" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="faq-answer" data-faq-answer={i}>
                <p class="text-neutral-600 text-base leading-relaxed pb-5">{faq.a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <FinalCTA />
  <Footer />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const index = (trigger as HTMLElement).dataset.faqIndex;
        const answer = document.querySelector(`[data-faq-answer="${index}"]`);
        const arrow = trigger.querySelector('.faq-arrow');
        const isOpen = answer?.classList.contains('open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-arrow').forEach(a => a.classList.remove('open'));
        document.querySelectorAll('.faq-trigger').forEach(t => t.setAttribute('aria-expanded', 'false'));

        // Toggle current
        if (!isOpen) {
          answer?.classList.add('open');
          arrow?.classList.add('open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>
